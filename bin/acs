#!/usr/bin/env bash
# acs — Agent Constraint System CLI
# npm install -g agent-constraint-system → acs <command>

set -e
PKG_DIR="$(cd "$(dirname "$(dirname "$0")")" && pwd)"

case "${1:-}" in
  install)
    shift
    if [[ $# -eq 0 ]]; then
      bash "$PKG_DIR/install.sh"
    elif [[ "$1" == "--all" ]]; then
      bash "$PKG_DIR/install.sh" --all
    else
      bash "$PKG_DIR/install.sh" "$@"
    fi
    ;;
  list|ls)
    bash "$PKG_DIR/install.sh" --list
    ;;
  status|verify)
    bash "$PKG_DIR/install.sh" --verify
    ;;
  version|-v|--version)
    echo "ACS v6.1.0"
    ;;
  *)
    echo "ACS v6.0 — Agent Constraint System"
    echo ""
    echo "Commands:"
    echo "  acs install [agent...]    Install constraint hooks for detected agents"
    echo "  acs install --all         Install all detected agents"
    echo "  acs list                  List supported agents"
    echo "  acs status                Check installation status"
    echo ""
    echo "After install, initialize each agent (e.g. acs_codex.py init)"
    ;;
esac
