{
  "description": "CACS v1.5 — Codex Agent Constraint System (full hook chain)",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.codex/hooks/acs_codex.py",
            "timeout": 5,
            "statusMessage": "CACS: Initializing"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.codex/hooks/acs_codex.py",
            "timeout": 10,
            "statusMessage": "CACS: Bash guard"
          },
          {
            "type": "command",
            "command": "python3 $HOME/.codebuddy/hooks/sed_guard.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 $HOME/.codebuddy/hooks/filesystem_guard.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.codex/hooks/acs_codex.py",
            "timeout": 10,
            "statusMessage": "CACS: File guard"
          },
          {
            "type": "command",
            "command": "python3 $HOME/.codebuddy/hooks/filesystem_guard.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.codebuddy/hooks/read_guard.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Write|Edit|MultiEdit|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.codex/hooks/acs_codex.py",
            "timeout": 10,
            "statusMessage": "CACS: Audit"
          },
          {
            "type": "command",
            "command": "python3 $HOME/.codebuddy/hooks/abi_guard.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 $HOME/.codebuddy/hooks/token_budget.py",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "python3 $HOME/.codebuddy/hooks/risk_engine.py assess --stdin",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.codebuddy/hooks/proposal_guard.py",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.codex/hooks/acs_codex.py",
            "timeout": 5,
            "statusMessage": "CACS: Session end"
          },
          {
            "type": "command",
            "command": "python3 $HOME/.codebuddy/hooks/stability_report.py check",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 $HOME/.codebuddy/hooks/runtime_loop.py tick --reason session_end",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
