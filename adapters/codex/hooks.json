{
  "description": "CACS v2.0 \u2014 Codex ACS (orchestrator mode)",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.codex/hooks/acs_orchestrator.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit|MultiEdit|apply_patch|Read",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.codex/hooks/acs_orchestrator.py",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Write|Edit|MultiEdit|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.codex/hooks/acs_orchestrator.py",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.codex/hooks/acs_orchestrator.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
